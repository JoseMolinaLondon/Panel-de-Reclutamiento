<script>
/* ============ DATA MODEL & CONSTANTS ============ */
const ETAPAS = [
  {id:1, nombre:"Postulaci\u00f3n", full:"Primer Filtro (Postulaci\u00f3n Vacante)"},
  {id:2, nombre:"Validaci\u00f3n CV", full:"Segundo Filtro (Filtro y Validaci\u00f3n CV's)"},
  {id:3, nombre:"Psicom\u00e9tricas", full:"Tercer Filtro (Pruebas Psicom\u00e9tricas)"},
  {id:4, nombre:"Entrevista RRHH/Ventas", full:"Cuarto Filtro (Entrevista RRHH/Ventas)"},
  {id:5, nombre:"Decisi\u00f3n Final", full:"Quinto Filtro (Entrevista y Decisi\u00f3n Final)"}
];
const STAGE_COLORS = ["#003DA5","#2B57AE","#B01C55","#E30613","#00A651"];
const ESTATUS_OPCIONES = ["","Pendiente","En proceso","Aprobado","Rechazado"];

const SEED_VACANTES = [
  {id:"V001", posicion:"Gerente de Territorio Interior #1", zona:"Territorial 1", fechaApertura:"2026-07-08", fechaCompromiso:"2026-08-10", estatus:"Abierta", fechaCierre:"", candidatoContratado:"", comentarios:"", postulacionRealizada:null, fechaPostulacion:""},
  {id:"V002", posicion:"Gerente de Zona 4", zona:"Zona 4", fechaApertura:"2026-07-08", fechaCompromiso:"2026-08-10", estatus:"Abierta", fechaCierre:"", candidatoContratado:"", comentarios:"", postulacionRealizada:null, fechaPostulacion:""},
  {id:"V003", posicion:"Gerente Sucursal #1", zona:"CV1", fechaApertura:"2026-07-08", fechaCompromiso:"2026-08-15", estatus:"Abierta", fechaCierre:"", candidatoContratado:"", comentarios:"", postulacionRealizada:null, fechaPostulacion:""},
  {id:"V004", posicion:"Gerente Sucursal #2", zona:"AP1", fechaApertura:"2026-07-08", fechaCompromiso:"2026-08-15", estatus:"Abierta", fechaCierre:"", candidatoContratado:"", comentarios:"", postulacionRealizada:null, fechaPostulacion:""},
  {id:"V005", posicion:"Gerente Sucursal #3", zona:"MT2", fechaApertura:"2026-07-08", fechaCompromiso:"2026-08-15", estatus:"Abierta", fechaCierre:"", candidatoContratado:"", comentarios:"", postulacionRealizada:null, fechaPostulacion:""},
  {id:"V006", posicion:"Supervisor CAT #1", zona:"Zona 3", fechaApertura:"2026-07-08", fechaCompromiso:"2026-08-10", estatus:"Abierta", fechaCierre:"", candidatoContratado:"", comentarios:"", postulacionRealizada:null, fechaPostulacion:""},
  {id:"V007", posicion:"Supervisor CAT #2", zona:"Zona 4", fechaApertura:"2026-07-08", fechaCompromiso:"2026-08-10", estatus:"Cerrada", fechaCierre:"2026-07-13", candidatoContratado:"Artemio Leal", comentarios:"Ingreso Artemio Leal", postulacionRealizada:null, fechaPostulacion:""}
];

function blankEtapas(){
  return ETAPAS.map(()=>({estatus:"", fecha:""}));
}

let state = {
  vacantes: JSON.parse(JSON.stringify(SEED_VACANTES)),
  candidatos: [],
  slaEtapas: [3,7,5,8,5],
  slaGeneral: 30,
  openVacId: null,
  presenting: false
};

/* ============ STORAGE (works inside Claude artifact viewer AND as standalone file) ============ */
const storage = {
  async get(key){
    if (window.storage){
      try { const r = await window.storage.get(key); return r ? r.value : null; } catch(e){ return null; }
    }
    try { return localStorage.getItem(key); } catch(e){ return null; }
  },
  async set(key, value){
    if (window.storage){
      try { await window.storage.set(key, value); return true; } catch(e){ /* fall through */ }
    }
    try { localStorage.setItem(key, value); return true; } catch(e){ return false; }
  }
};
const STORE_KEY = "transformar_reclutamiento_v1";

async function loadState(){
  try{
    const raw = await storage.get(STORE_KEY);
    if (raw){
      const parsed = JSON.parse(raw);
      state = Object.assign(state, parsed);
      state.vacantes = (state.vacantes || []).map(v=>Object.assign({postulacionRealizada:null,fechaPostulacion:""},v));
      state.candidatos = state.candidatos || [];
    }
  }catch(e){ console.warn("No se pudo cargar estado guardado", e); }
}
let saveTimer=null;
function saveState(){
  clearTimeout(saveTimer);
  saveTimer = setTimeout(async ()=>{
    await storage.set(STORE_KEY, JSON.stringify(state));
    const el = document.getElementById("lastSaved");
    el.textContent = "Guardado " + new Date().toLocaleTimeString('es-MX',{hour:'2-digit',minute:'2-digit'});
  }, 250);
}

/* ============ UTILITIES ============ */
function uid(prefix){ return prefix + Math.random().toString(36).slice(2,9); }
function todayISO(){ return new Date().toISOString().slice(0,10); }
function daysBetween(a,b){
  if(!a||!b) return null;
  const d1=new Date(a+"T00:00:00"), d2=new Date(b+"T00:00:00");
  return Math.round((d2-d1)/86400000);
}
function fmtDate(iso){
  if(!iso) return "&mdash;";
  const d = new Date(iso+"T00:00:00");
  return d.toLocaleDateString('es-MX',{day:'2-digit',month:'short',year:'2-digit'});
}
function escapeHtml(s){
  return (s||"").replace(/[&<>"']/g, m=>({"&":"&amp;","<":"&lt;",">":"&gt;",'"':"&quot;","'":"&#39;"}[m]));
}
function toast(msg){
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  clearTimeout(t._h);
  t._h = setTimeout(()=>t.classList.remove("show"), 2200);
}

function candidatosDeVacante(vid){
  return state.candidatos.filter(c=>c.vacanteId===vid);
}

function etapaActual(cand){
  for (let i=0;i<5;i++){
    const st = cand.etapas[i].estatus;
    if (st === "Rechazado") return {label:"Descartado \u2013 Etapa "+(i+1), type:"rechazado", idx:i};
    if (st === "Pendiente" || st === "En proceso") return {label:"Etapa "+(i+1)+": "+ETAPAS[i].nombre, type:"activo", idx:i};
    if (st === "Aprobado") continue;
    if (!st){
      if (i===0) return {label:"Sin iniciar", type:"sin_iniciar", idx:-1};
      return {label:"Aprob\u00f3 Etapa "+i+" \u2013 pendiente avanzar", type:"pendiente_avance", idx:i-1};
    }
  }
  return {label:"Contratado / Proceso completo", type:"contratado", idx:4};
}

function diasEnEtapaActual(cand, ea){
  if (ea.idx < 0) return null;
  const fecha = cand.etapas[ea.idx].fecha;
  if (!fecha) return null;
  return daysBetween(fecha, todayISO());
}

function semaforoCandidato(cand, ea){
  const dias = diasEnEtapaActual(cand, ea);
  if (dias === null || ea.type==="contratado" || ea.type==="rechazado") return "gris";
  const sla = state.slaEtapas[ea.idx] || 5;
  const ratio = dias / sla;
  if (ratio <= 0.7) return "verde";
  if (ratio <= 1.0) return "amarillo";
  return "rojo";
}

function semaforoVacante(vac){
  if (vac.estatus === "Cerrada") return "gris";
  if (vac.estatus === "Cancelada") return "gris";
  const dias = daysBetween(vac.fechaApertura, todayISO());
  if (dias===null) return "gris";
  const sla = state.slaGeneral || 30;
  const ratio = dias/sla;
  if (ratio<=0.7) return "verde";
  if (ratio<=1.0) return "amarillo";
  return "rojo";
}

/* ============ RENDER: KPIs ============ */
function renderKpis(){
  const abiertas = state.vacantes.filter(v=>v.estatus==="Abierta").length;
  const cerradas = state.vacantes.filter(v=>v.estatus==="Cerrada").length;
  const candActivos = state.candidatos.filter(c=>{
    const ea = etapaActual(c);
    return ea.type==="activo" || ea.type==="pendiente_avance" || ea.type==="sin_iniciar";
  }).length;
  const abiertasArr = state.vacantes.filter(v=>v.estatus==="Abierta");
  const diasProm = abiertasArr.length ? Math.round(abiertasArr.reduce((s,v)=>s+(daysBetween(v.fechaApertura,todayISO())||0),0)/abiertasArr.length) : 0;
  const rojas = state.vacantes.filter(v=>semaforoVacante(v)==="rojo").length;

  document.getElementById("kpiAbiertas").textContent = abiertas;
  document.getElementById("kpiCerradas").textContent = cerradas;
  document.getElementById("kpiCandidatos").textContent = candActivos;
  document.getElementById("kpiDiasProm").textContent = diasProm;
  document.getElementById("kpiRojo").textContent = rojas;
}

/* ============ RENDER: FUNNEL ============ */
function renderFunnel(){
  const track = document.getElementById("funnelTrack");
  const summary = document.getElementById("funnelSummary");
  const footnote = document.getElementById("funnelFootnote");
  track.innerHTML = "";

  // Etapa 1 se contabiliza por vacante marcada con postulación = Sí.
  // Etapas 2 a 5 se contabilizan por candidatos con avance registrado.
  const postulaciones = state.vacantes.filter(v=>v.postulacionRealizada===true).length;
  const candidateCounts = ETAPAS.slice(1).map((e,i)=> state.candidatos.filter(c=>c.etapas[i+1] && c.etapas[i+1].estatus).length);
  const counts = [postulaciones, ...candidateCounts];
  const base = counts[0] || 0;
  const denominator = Math.max(base,1);
  const finalCount = counts[4] || 0;
  const globalConversion = base ? Math.round((finalCount/base)*100) : 0;
  const activeVacancies = state.vacantes.filter(v=>v.estatus === "Abierta").length;

  summary.innerHTML = `
    <div class="funnel-summary-chip"><strong>${base}</strong><span>Vacantes con postulación</span></div>
    <div class="funnel-summary-chip"><strong>${globalConversion}%</strong><span>Conversión final</span></div>
    <div class="funnel-summary-chip"><strong>${activeVacancies}</strong><span>Vacantes activas</span></div>`;

  const labels = ["Postulación","Validación CV","Psicométricas","Entrevista","Decisión final"];
  const icons = ["▤","●","▣","★","⚡"];
  const heights = [250,220,192,166,140];
  ETAPAS.forEach((e,i)=>{
    const prior = i===0 ? counts[0] : counts[i-1];
    const accumulated = Math.round((counts[i]/denominator)*100);
    const conversion = i===0 ? 100 : (prior ? Math.round((counts[i]/prior)*100) : 0);
    const drop = i===0 ? 0 : Math.max(prior-counts[i],0);
    const dropPct = i===0 || !prior ? 0 : Math.round((drop/prior)*100);
    const seg=document.createElement("div");
    seg.className="funnel-seg";
    seg.style.setProperty('--funnel-h',heights[i]+'px');
    seg.style.setProperty('--stage',STAGE_COLORS[i]);
    seg.style.setProperty('--stage-light',STAGE_COLORS[i]+'CC');
    seg.innerHTML=`
      <div class="shape"></div>
      <div class="content">
        <div class="stage-index">${i+1}</div>
        <div class="stage-icon">${icons[i]}</div>
        <div class="stage-name">${labels[i]}</div>
        <div class="count">${counts[i]}</div>
        <div class="pct">${i===0?'100% del universo':accumulated+'% del universo'}</div>
      </div>
      ${i<4?`<div class="conversion-badge">${counts[i]?Math.round((counts[i+1]/counts[i])*100):0}%</div>`:''}
      <div class="funnel-drop-card ${i===0?'entry':''}"><strong>${i===0?'—':'−'+drop}</strong>${i===0?'Inicio del embudo':dropPct+'% pérdida vs. anterior'}</div>`;
    track.appendChild(seg);
  });

  const drops=counts.slice(1).map((n,i)=>({drop:Math.max(counts[i]-n,0),from:labels[i],to:labels[i+1]}));
  const biggest=drops.reduce((a,b)=>b.drop>a.drop?b:a,{drop:0,from:'',to:''});
  footnote.innerHTML=`<span><strong>Cómo se calcula:</strong> conversión de cada etapa contra la etapa anterior.</span><span><strong>Mayor fuga:</strong> ${biggest.drop?`${biggest.from} → ${biggest.to} (${biggest.drop})`:'Sin pérdida registrada'}</span>`;
}
/* ============ RENDER: VACANTES ============ */
function badgeClassEstatus(estatus){
  return {"Abierta":"abierta","Cerrada":"cerrada","Cancelada":"cancelada","Pausada":"pausada"}[estatus] || "abierta";
}

function stageSelectClass(val){
  return {"":"st-empty","Pendiente":"st-pendiente","En proceso":"st-enproceso","Aprobado":"st-aprobado","Rechazado":"st-rechazado"}[val];
}

function renderVacantes(){
  const grid = document.getElementById("vacGrid");
  grid.innerHTML = "";

  state.vacantes.forEach(vac=>{
    const cands = candidatosDeVacante(vac.id);
    const sem = semaforoVacante(vac);
    const dias = daysBetween(vac.fechaApertura, todayISO());
    const isOpen = state.openVacId === vac.id;

    const card = document.createElement("div");
    card.className = "vac-card" + (isOpen ? " open" : "");

    const semLabel = vac.estatus==="Cerrada" ? "Cerrada" : vac.estatus==="Cancelada" ? "Cancelada" : {verde:"En tiempo",amarillo:"Por vencer",rojo:"Atrasada",gris:"\u2014"}[sem];

    card.innerHTML = `
      <div class="vac-summary" data-vid="${vac.id}">
        <div class="vac-pos">
          <span class="name">${escapeHtml(vac.posicion)}</span>
          <span class="zone">${escapeHtml(vac.zona || "Sin zona asignada")}</span>
        </div>
        <div><span class="col-lbl">Estatus</span><span class="badge ${badgeClassEstatus(vac.estatus)}">${vac.estatus}</span></div>
        <div><span class="col-lbl">Apertura</span><span class="col-val">${fmtDate(vac.fechaApertura)}</span></div>
        <div><span class="col-lbl">Compromiso</span><span class="col-val">${fmtDate(vac.fechaCompromiso)}</span></div>
        <div><span class="col-lbl">D\u00edas</span><span class="col-val">${dias===null?"&mdash;":dias}</span></div>
        <div><span class="col-lbl">Sem\u00e1foro</span><span class="semaforo-txt"><span class="dot ${sem}"></span>${semLabel}</span></div>
        <div style="display:flex;align-items:center;gap:8px;">
          <span class="col-val no-present" style="color:#9aa2b1;font-size:12px;">${cands.length} cand.</span>
          <button class="btn small no-present" data-action="editvac" data-vid="${vac.id}">Editar</button>
          <span class="chev">&#10148;</span>
        </div>
      </div>
      <div class="vac-detail">
        ${vac.estatus==="Cerrada" ? `<div class="detail-row"><div class="detail-block"><label>Candidato contratado</label><div class="col-val" style="font-size:15px;">${escapeHtml(vac.candidatoContratado)||"&mdash;"}</div></div><div class="detail-block"><label>Fecha de cierre</label><div class="col-val">${fmtDate(vac.fechaCierre)}</div></div></div>` : ``}
        <div class="detail-row">
          <div class="detail-block" style="flex:2;">
            <label>Comentarios generales de la vacante</label>
            <textarea data-action="comentvac" data-vid="${vac.id}" rows="2">${escapeHtml(vac.comentarios)}</textarea>
          </div>
        </div>
        <div class="postulacion-control no-present">
          <div class="postulacion-copy">
            <strong>¿Se realizó la postulación de la vacante?</strong>
            <span>Este dato alimenta la primera etapa del embudo global.</span>
          </div>
          <div class="binary-options">
            <label class="binary-option"><input type="radio" name="post_${vac.id}" data-action="postulacion" data-vid="${vac.id}" value="si" ${vac.postulacionRealizada===true?'checked':''}><span>Sí</span></label>
            <label class="binary-option no"><input type="radio" name="post_${vac.id}" data-action="postulacion" data-vid="${vac.id}" value="no" ${vac.postulacionRealizada===false?'checked':''}><span>No</span></label>
          </div>
        </div>
        <div class="cand-header">
          <h3>Candidatos (${cands.length})</h3>
          <button class="btn small primary no-present" data-action="addcand" data-vid="${vac.id}">+ Agregar candidato</button>
        </div>
        <div class="cand-list">
          ${cands.length ? cands.map(c=>renderCandidato(c)).join("") : `<div class="empty-note">A\u00fan no hay candidatos registrados para esta vacante.</div>`}
        </div>
      </div>
    `;
    grid.appendChild(card);
  });
}

function renderCandidato(cand){
  const ea = etapaActual(cand);
  const sem = semaforoCandidato(cand, ea);
  const dias = diasEnEtapaActual(cand, ea);

  const stagesHtml = ETAPAS.map((e,i)=>{
    const val = cand.etapas[i].estatus;
    const opts = ESTATUS_OPCIONES.map(o=>`<option value="${o}" ${o===val?"selected":""}>${o||"\u2013"}</option>`).join("");
    return `
      <div class="stage-pill">
        <label>${e.nombre}</label>
        <select class="${stageSelectClass(val)}" data-action="stage" data-cid="${cand.id}" data-stage="${i}">${opts}</select>
        <div class="stage-meta">${cand.etapas[i].fecha ? fmtDate(cand.etapas[i].fecha) : "&nbsp;"}</div>
      </div>`;
  }).join("");

  const commentsHtml = (cand.comentarios||[]).slice().reverse().map(cm=>`
      <div class="comment-item"><div class="meta">${fmtDate(cm.fecha)}</div>${escapeHtml(cm.texto)}</div>
  `).join("") || `<div class="empty-note">Sin comentarios a\u00fan.</div>`;

  return `
    <div class="cand-card">
      <div class="cand-top">
        <span class="cand-name">${escapeHtml(cand.nombre)}</span>
        <span class="cand-stage-badge ${ea.type}">${ea.label}</span>
        <button class="btn small danger ghost no-present" data-action="delcand" data-cid="${cand.id}" style="margin-left:auto;">Eliminar</button>
      </div>
      <div class="stage-track">${stagesHtml}</div>
      <div class="cand-foot">
        <span class="cand-days">${dias!==null ? dias+" d\u00edas en etapa actual" : ""}</span>
        <span class="semaforo-txt"><span class="dot ${sem}"></span></span>
      </div>
      <div class="comments">
        <div class="comment-add no-present">
          <input type="text" placeholder="Agregar comentario sobre este candidato..." data-action="commentinput" data-cid="${cand.id}">
          <button class="btn small" data-action="addcomment" data-cid="${cand.id}">Agregar</button>
        </div>
        <div class="comment-log">${commentsHtml}</div>
      </div>
    </div>
  `;
}

function renderAll(){
  renderKpis();
  renderFunnel();
  renderVacantes();
  document.getElementById("todayChip").textContent = new Date().toLocaleDateString('es-MX',{weekday:'long',day:'numeric',month:'long',year:'numeric'});
}

/* ============ EVENT HANDLERS ============ */
document.addEventListener("click", (e)=>{
  const t = e.target;

  const summary = t.closest(".vac-summary");
  if (summary && !t.closest("button")){
    const vid = summary.dataset.vid;
    state.openVacId = state.openVacId === vid ? null : vid;
    renderVacantes();
    return;
  }

  const action = t.dataset && t.dataset.action;
  if (!action) return;

  if (action==="editvac"){
    e.stopPropagation();
    openVacModal(t.dataset.vid);
  }
  if (action==="addcand"){
    e.stopPropagation();
    document.getElementById("candVacId").value = t.dataset.vid;
    document.getElementById("fCandNombre").value = "";
    document.getElementById("overlayCand").classList.add("show");
  }
  if (action==="delcand"){
    e.stopPropagation();
    if (confirm("\u00bfEliminar este candidato del proceso?")){
      state.candidatos = state.candidatos.filter(c=>c.id!==t.dataset.cid);
      saveState(); renderAll();
    }
  }
  if (action==="addcomment"){
    e.stopPropagation();
    const input = document.querySelector(`input[data-action="commentinput"][data-cid="${t.dataset.cid}"]`);
    const val = input.value.trim();
    if (!val) return;
    const cand = state.candidatos.find(c=>c.id===t.dataset.cid);
    cand.comentarios = cand.comentarios || [];
    cand.comentarios.push({fecha: todayISO(), texto: val});
    saveState(); renderAll();
  }
});

document.addEventListener("change", (e)=>{
  const t = e.target;
  const action = t.dataset && t.dataset.action;
  if (action==="stage"){
    const cand = state.candidatos.find(c=>c.id===t.dataset.cid);
    const idx = parseInt(t.dataset.stage,10);
    cand.etapas[idx].estatus = t.value;
    cand.etapas[idx].fecha = t.value ? todayISO() : "";
    saveState(); renderAll();
  }
  if (action==="postulacion"){
    const vac = state.vacantes.find(v=>v.id===t.dataset.vid);
    if (vac){
      vac.postulacionRealizada = t.value === "si";
      vac.fechaPostulacion = vac.postulacionRealizada ? (vac.fechaPostulacion || todayISO()) : "";
      saveState(); renderAll();
      toast(vac.postulacionRealizada ? "Postulación confirmada" : "Postulación marcada como no realizada");
    }
  }
});

document.addEventListener("blur", (e)=>{
  const t = e.target;
  if (t.dataset && t.dataset.action==="comentvac"){
    const vac = state.vacantes.find(v=>v.id===t.dataset.vid);
    vac.comentarios = t.value;
    saveState();
  }
}, true);

/* ---- Vacante modal ---- */
function openVacModal(vid){
  const isNew = !vid;
  document.getElementById("vacModalTitle").textContent = isNew ? "Nueva vacante" : "Editar vacante";
  document.getElementById("vacEditId").value = vid || "";
  document.getElementById("btnDeleteVac").style.display = isNew ? "none" : "inline-flex";
  if (isNew){
    document.getElementById("fPosicion").value = "";
    document.getElementById("fZona").value = "";
    document.getElementById("fEstatus").value = "Abierta";
    document.getElementById("fFechaApertura").value = todayISO();
    document.getElementById("fFechaCompromiso").value = "";
    document.getElementById("fComentarios").value = "";
  } else {
    const vac = state.vacantes.find(v=>v.id===vid);
    document.getElementById("fPosicion").value = vac.posicion;
    document.getElementById("fZona").value = vac.zona;
    document.getElementById("fEstatus").value = vac.estatus;
    document.getElementById("fFechaApertura").value = vac.fechaApertura;
    document.getElementById("fFechaCompromiso").value = vac.fechaCompromiso;
    document.getElementById("fComentarios").value = vac.comentarios;
  }
  document.getElementById("overlayVac").classList.add("show");
}
document.getElementById("btnNuevaVacante").addEventListener("click", ()=>openVacModal(null));
document.getElementById("btnCancelVac").addEventListener("click", ()=>document.getElementById("overlayVac").classList.remove("show"));
document.getElementById("btnSaveVac").addEventListener("click", ()=>{
  const id = document.getElementById("vacEditId").value;
  const posicion = document.getElementById("fPosicion").value.trim();
  if (!posicion){ toast("Escribe el nombre de la posici\u00f3n"); return; }
  const data = {
    posicion,
    zona: document.getElementById("fZona").value.trim(),
    estatus: document.getElementById("fEstatus").value,
    fechaApertura: document.getElementById("fFechaApertura").value,
    fechaCompromiso: document.getElementById("fFechaCompromiso").value,
    comentarios: document.getElementById("fComentarios").value
  };
  if (id){
    const vac = state.vacantes.find(v=>v.id===id);
    Object.assign(vac, data);
  } else {
    state.vacantes.push(Object.assign({id: uid("V"), fechaCierre:"", candidatoContratado:"", postulacionRealizada:null, fechaPostulacion:""}, data));
  }
  document.getElementById("overlayVac").classList.remove("show");
  saveState(); renderAll();
  toast("Vacante guardada");
});
document.getElementById("btnDeleteVac").addEventListener("click", ()=>{
  const id = document.getElementById("vacEditId").value;
  if (!id) return;
  if (confirm("\u00bfEliminar esta vacante y todos sus candidatos?")){
    state.vacantes = state.vacantes.filter(v=>v.id!==id);
    state.candidatos = state.candidatos.filter(c=>c.vacanteId!==id);
    document.getElementById("overlayVac").classList.remove("show");
    saveState(); renderAll();
  }
});

/* ---- Candidato modal ---- */
document.getElementById("btnCancelCand").addEventListener("click", ()=>document.getElementById("overlayCand").classList.remove("show"));
document.getElementById("btnSaveCand").addEventListener("click", ()=>{
  const vid = document.getElementById("candVacId").value;
  const nombre = document.getElementById("fCandNombre").value.trim();
  if (!nombre){ toast("Escribe el nombre del candidato"); return; }
  state.candidatos.push({id: uid("C"), vacanteId: vid, nombre, etapas: blankEtapas(), comentarios: []});
  document.getElementById("overlayCand").classList.remove("show");
  saveState(); renderAll();
  toast("Candidato agregado");
});

/* ---- SLA modal ---- */
document.getElementById("btnSettings").addEventListener("click", ()=>{
  const cont = document.getElementById("slaFields");
  cont.innerHTML = ETAPAS.map((e,i)=>`
    <div class="field-row" style="align-items:center;margin-bottom:8px;">
      <div style="flex:2;font-size:13px;font-weight:600;">${e.nombre}</div>
      <div class="field" style="flex:1;margin-bottom:0;"><input type="number" min="1" id="slaEtapa${i}" value="${state.slaEtapas[i]}"></div>
    </div>`).join("");
  document.getElementById("fSlaGeneral").value = state.slaGeneral;
  document.getElementById("overlaySla").classList.add("show");
});
document.getElementById("btnCancelSla").addEventListener("click", ()=>document.getElementById("overlaySla").classList.remove("show"));
document.getElementById("btnSaveSla").addEventListener("click", ()=>{
  state.slaEtapas = ETAPAS.map((e,i)=> parseInt(document.getElementById("slaEtapa"+i).value,10) || state.slaEtapas[i]);
  state.slaGeneral = parseInt(document.getElementById("fSlaGeneral").value,10) || state.slaGeneral;
  document.getElementById("overlaySla").classList.remove("show");
  saveState(); renderAll();
  toast("SLA actualizado");
});

/* ---- Presentation mode ---- */
document.getElementById("btnPresent").addEventListener("click", ()=>{
  state.presenting = !state.presenting;
  document.getElementById("app").classList.toggle("presenting", state.presenting);
  document.getElementById("btnPresent").textContent = state.presenting ? "\u2715 Salir de presentaci\u00f3n" : "\uD83D\uDC41\uFE0F Modo presentaci\u00f3n";
});

/* ---- Export / Import ---- */
document.getElementById("btnExport").addEventListener("click", ()=>{
  const blob = new Blob([JSON.stringify(state,null,2)], {type:"application/json"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement("a");
  a.href = url; a.download = "transformar_reclutamiento_respaldo_"+todayISO()+".json";
  a.click(); URL.revokeObjectURL(url);
  toast("Respaldo descargado");
});
document.getElementById("btnImport").addEventListener("click", ()=>document.getElementById("fileImport").click());
document.getElementById("fileImport").addEventListener("change", (e)=>{
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = (ev)=>{
    try{
      const parsed = JSON.parse(ev.target.result);
      state = Object.assign(state, parsed);
      saveState(); renderAll();
      toast("Datos cargados correctamente");
    }catch(err){ alert("El archivo no es un respaldo v\u00e1lido de TransforMAR."); }
  };
  reader.readAsText(file);
  e.target.value = "";
});

/* ============ INIT ============ */
(async function init(){
  await loadState();
  renderAll();
})();
</script>
</body>
</html>
